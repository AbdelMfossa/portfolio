[Unit]
Description=gunicorn daemon for abdelmfossa
Requires=gunicorn_abdelmfossa.socket
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/var/www/abdelmfossa
ExecStart=/var/www/abdelmfossa/venv/bin/gunicorn \
          --access-logfile - \
          --workers 3 \
          --bind unix:/run/gunicorn_abdelmfossa.sock \
          config.wsgi:application

[Install]
WantedBy=multi-user.target
